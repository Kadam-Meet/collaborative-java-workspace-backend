# Example values only. Do not commit real secrets.
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
# Use a random secret with at least 32 characters.
APP_JWT_SECRET=replace_with_random_secret_min_32_chars
APP_JWT_EXPIRATION_SECONDS=86400
# Optional: add your Vercel production/custom domain(s) as comma-separated origin patterns.
# Example: https://my-app.vercel.app,https://app.mycustomdomain.com
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://*.vercel.app,http://localhost:*,http://127.0.0.1:*
APP_FRONTEND_BASE_URL=https://collaborative-java-workspace-fronte-theta.vercel.app
APP_PASSWORD_RESET_EXPIRATION_MINUTES=60
APP_INVITATION_EXPIRATION_HOURS=72
